<Window x:Class="App2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App2"
        mc:Ignorable="d"
        Title="نظام إدارة المبيعات" Height="800" Width="1400"
        Icon="Resources/app_icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style TargetType="RadioButton" x:Key="NavButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Title -->
                <StackPanel Grid.Row="0" Margin="24,32,24,32" Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="ادارة المخازن" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Links -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,0">
                        <TextBlock Text="القائمة الرئيسية" FontSize="12" Foreground="#64748B" FontWeight="Bold" Margin="16,0,0,12"/>
                        
                        <RadioButton Content="🏠 لوحة التحكم" Style="{StaticResource NavButtonStyle}" Command="{Binding GoToDashboardCommand}" IsChecked="True"/>
                        <RadioButton Content="💼 دليل الحسابات" Style="{StaticResource NavButtonStyle}" Command="{Binding ManageAccountsCommand}"/>
                        <RadioButton Content="👥 إدارة العملاء" Style="{StaticResource NavButtonStyle}" Command="{Binding ManageCustomersCommand}"/>
                        <RadioButton Content="📦 إدارة المخزون" Style="{StaticResource NavButtonStyle}" Command="{Binding ManageInventoryCommand}"/>
                        <RadioButton Content="🧾 سجل المبيعات" Style="{StaticResource NavButtonStyle}" Command="{Binding ManageSalesLogCommand}"/>
                        <RadioButton Content="🧾 سجل المشتريات" Style="{StaticResource NavButtonStyle}" Command="{Binding ManagePurchaseInvoicesCommand}"/>
                        
                        <!-- These commands aren't fully implemented with views yet, but they exist in ViewModel -->
                        <RadioButton Content="📊 التقارير" Style="{StaticResource NavButtonStyle}" Command="{Binding ReportsCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: User Info + Settings + Logout -->
                <StackPanel Grid.Row="2" Margin="16,16,16,24">
                    <Rectangle Fill="#F1F5F9" Height="1" Margin="0,0,0,16"/>

                    <!-- User Info -->
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#EFF6FF" CornerRadius="20" Width="38" Height="38" Margin="0,0,10,0">
                                <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentFullName}" FontSize="13" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="{Binding CurrentUsername}" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <RadioButton Content="⚙️ الإعدادات" Style="{StaticResource NavButtonStyle}" Command="{Binding SettingsCommand}"/>

                    <!-- Logout Button -->
                    <Button Command="{Binding LogoutCommand}" Cursor="Hand" Margin="0,4,0,0"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚪" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="تسجيل الخروج" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#EF4444" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FEF2F2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#F8FAFC">
            <!-- This will display the CurrentView property from MainViewModel -->
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>
        </Border>
    </Grid>
</Window>
