<Window x:Class="App2.Views.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:App2.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="بيانات الحساب" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FlowDirection="RightToLeft">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="اسم الحساب" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Padding="12,10" FontSize="15" Margin="0,0,0,16"
                 Background="White" BorderBrush="#CBD5E1" BorderThickness="1"/>

        <TextBlock Grid.Row="2" Text="كود الحساب (اختياري)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
        <TextBox x:Name="CodeTextBox" Grid.Row="3" Padding="12,10" FontSize="15" Margin="0,0,0,16"
                 Background="White" BorderBrush="#CBD5E1" BorderThickness="1"/>

        <TextBlock Grid.Row="4" Text="نوع الحساب" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
        <ComboBox x:Name="TypeComboBox" Grid.Row="5" Padding="12,10" FontSize="15" Margin="0,0,0,16"
                  Background="White" BorderBrush="#CBD5E1" BorderThickness="1" VerticalAlignment="Top"/>
        
        <CheckBox x:Name="IsActiveCheckBox" Grid.Row="5" Content="حساب نشط" VerticalAlignment="Center" Margin="0,60,0,0" IsChecked="True"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="إلغاء" Width="100" Padding="0,10" Margin="0,0,12,0" 
                    Background="White" Foreground="#475569" BorderBrush="#CBD5E1"
                    Click="CancelButton_Click"/>
            
            <Button Content="حفظ" Width="100" Padding="0,10" 
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
