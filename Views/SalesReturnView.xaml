<UserControl x:Class="App2.Views.SalesReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewModels="clr-namespace:App2.ViewModels"
             Background="#E2E8F0" 
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <x:Array x:Key="UnitStrings" Type="sys:String">
            <sys:String>كرتون</sys:String>
            <sys:String>كبة</sys:String>
        </x:Array>
        <viewModels:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="RoundedActionBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SolidCheckoutBtn">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#FFFFFF" Margin="0,0,15,0" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,2" Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="رقم المرتجع:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReturnNumber}" FontSize="18" FontWeight="Black" Foreground="#0F172A" Margin="0,0,30,0" VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#CBD5E1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="التاريخ:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <DatePicker SelectedDate="{Binding ReturnDate}" FontSize="15" Foreground="#334155" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Transaction Type is always Return, so hide this section -->
                <Border Grid.Row="1" Padding="20,15" Visibility="Collapsed">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="نوع العملية:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="مرتجع" GroupName="ReturnType" 
                                         IsChecked="True"
                                         Margin="0,0,20,0"/>
                            <RadioButton Content="استبدال" GroupName="ReturnType" 
                                         IsChecked="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Padding="20,15">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="اختيار الفاتورة:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="SearchInvoiceBox" 
                                     Text="{Binding SearchInvoiceText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="SearchInvoiceBox_PreviewKeyDown"
                                     Background="#F8FAFC" BorderBrush="#E2E8F0" Height="45" FontSize="16" VerticalContentAlignment="Center" Padding="10,0"/>
                            
                            <Popup IsOpen="{Binding IsInvoiceDropdownOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=SearchInvoiceBox}" MaxHeight="300" Width="{Binding ActualWidth, ElementName=SearchInvoiceBox}">
                                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                                    <ListBox x:Name="InvoiceListBox" ItemsSource="{Binding FilteredInvoices}" 
                                             SelectedItem="{Binding SelectedInvoice}" 
                                             PreviewKeyDown="InvoiceListBox_PreviewKeyDown"
                                             MouseLeftButtonUp="InvoiceListBox_MouseLeftButtonUp"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,10">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding InvoiceNumber}" FontWeight="SemiBold" FontSize="15" Foreground="#1E293B"/>
                                                        <TextBlock Text=" - " Foreground="#94A3B8" FontSize="15"/>
                                                        <TextBlock Text="{Binding Customer.Name}" FontSize="15" Foreground="#1E293B"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Margin" Value="2"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                        <TextBlock Text="{Binding SelectedCustomerName}" Foreground="#3B82F6" FontWeight="Bold" Margin="0,10,0,0"/>
                        
                        <!-- Search products for Exchange mode -->
                        <StackPanel Margin="0,15,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedType}" Value="Exchange">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="البحث برقم الخيط أو الوصف (لإضافة أصناف):" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid>
                                <TextBox x:Name="SearchItemBox" 
                                         Text="{Binding SearchItemNumber, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewKeyDown="SearchItemBox_PreviewKeyDown"
                                         Background="#F8FAFC" BorderBrush="#E2E8F0" Height="45" FontSize="16" VerticalContentAlignment="Center" Padding="10,0"/>

                                <Popup IsOpen="{Binding IsItemDropdownOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=SearchItemBox}" MaxHeight="300" Width="{Binding ActualWidth, ElementName=SearchItemBox}">
                                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                                        <ListBox x:Name="ItemListBox" ItemsSource="{Binding AvailableBatches}" 
                                                 SelectedItem="{Binding SelectedBatch}" 
                                                 PreviewKeyDown="ItemListBox_PreviewKeyDown"
                                                 MouseLeftButtonUp="ItemListBox_MouseLeftButtonUp"
                                                 Background="Transparent" BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" Padding="8,10" Foreground="#1E293B" FontSize="15"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Margin" Value="2"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3" Background="White" BorderThickness="1" BorderBrush="#E2E8F0" HeadersVisibility="Column" 
                          RowHeight="50" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          Margin="20,0,20,20" ItemsSource="{Binding Items}" AutoGenerateColumns="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الباركود/رقم الصنف" Binding="{Binding ThreadNumber}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="البيان" Binding="{Binding ItemName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="الكمية المُرجعة" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="140">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="InputScope" Value="Number"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="الحد الأقصى" Binding="{Binding MaxReturnQuantityDisplay}" Width="140" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="الوحدة" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding UnitName}" Padding="10,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox 
                                        ItemsSource="{Binding Source={StaticResource UnitStrings}}" 
                                        SelectedItem="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanChangeUnit}"
                                        Padding="10,0"
                                        VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="السعر" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SalesInvoiceDetailId}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalPrice}" Width="140" IsReadOnly="True"/>
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✖" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontWeight="Black" Cursor="Hand" FontSize="16"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="#0F172A" CornerRadius="8" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="ملاحظات:" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Notes}" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>
                    
                    <!-- Payment Method Panel - only visible for Return Type -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedType}" Value="Exchange">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <TextBlock Text="طريقة إرجاع المبلغ:" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,20,0,8"/>
                        <RadioButton Content="إلى حساب العميل" GroupName="ReturnMethod" IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ToCustomerAccount}" 
                                     Foreground="#F8FAFC" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton Content="نقدي من الصندوق" GroupName="ReturnMethod" IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Cash}" 
                                     Foreground="#F8FAFC" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton Content="تحويل/شبكة" GroupName="ReturnMethod" IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Transfer}" 
                                     Foreground="#F8FAFC" FontSize="14" FontWeight="SemiBold"/>
                        
                        <TextBlock Text="رقم الحوالة:" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,15,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPaymentMethod}" Value="Transfer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding TransferNumber}" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPaymentMethod}" Value="Transfer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#334155" BorderThickness="0,2,0,2" Padding="0,20,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Total Amount (only visible for Return) -->
                        <Grid Grid.Row="0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedType}" Value="Exchange">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="إجمالي المرتجع" Foreground="#EF4444" FontSize="22" FontWeight="Black" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat=N2}" Foreground="#EF4444" FontSize="36" FontWeight="Black"/>
                        </Grid>
                        
                        <!-- Quantity (only visible for Exchange) -->
                        <StackPanel Grid.Row="0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedType}" Value="Exchange">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="الكمية المطلوبة:" Foreground="#94A3B8" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OriginalInvoiceTotalQuantityKabba, StringFormat=' {0} كبة'}" Foreground="#10B981" FontSize="18" FontWeight="Black" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="الكمية الحالية:" Foreground="#94A3B8" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ItemsTotalQuantityKabba, StringFormat=' {0} كبة'}" Foreground="#3B82F6" FontSize="18" FontWeight="Black" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Grid.Row="2" Height="65" Margin="0,30,0,0" Command="{Binding SaveReturnCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SolidCheckoutBtn}">
                            <Setter Property="Content" Value="حفظ المرتجع"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedType}" Value="Exchange">
                                    <Setter Property="Content" Value="حفظ الاستبدال"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
