<Window x:Class="App2.Views.PaymentReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل دفعة عميل"
        Width="450" Height="520"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F8FAFC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="تسجيل دفعة" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" Padding="16" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="العميل:" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SelectedCustomer.Name}" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="المبلغ المدفوع:" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource RoundedTextBox}"
                     Height="45" FontSize="18" 
                     BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="طريقة الدفع:" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="نقدي" GroupName="PaymentMethod" IsChecked="True" Margin="0,0,20,0" FontSize="16" VerticalAlignment="Center" Checked="PaymentMethod_Checked"/>
                <RadioButton Content="تحويل" GroupName="PaymentMethod" FontSize="16" VerticalAlignment="Center" Checked="PaymentMethod_Checked"/>
            </StackPanel>
            <TextBlock Text="{Binding PaymentType}" Foreground="Red" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PaymentType}" Value="تحويل">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="رقم الحوالة:" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox Text="{Binding TransferNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RoundedTextBox}" 
                     Height="45" FontSize="16" BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
        </StackPanel>

        <Button Grid.Row="6" Content="حفظ الدفعة" Command="{Binding SavePaymentCommand}" 
                IsEnabled="{Binding IsSaveEnabled}" FontSize="18" FontWeight="Bold"
                Background="#10B981" Foreground="White" Height="50" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>