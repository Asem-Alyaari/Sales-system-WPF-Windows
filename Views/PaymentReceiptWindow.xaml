<Window x:Class="App2.Views.PaymentReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="تسجيل دفعة عميل"
        Width="500"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F8FAFC" Height="500">
    <Grid Margin="24,24,10,-17">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="76.257"/>
            <RowDefinition Height="18"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="تسجيل دفعة" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24"/>

        <Border Grid.Row="1" Background="White" Padding="16" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="العميل:" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SelectedCustomer.Name}" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="المبلغ المدفوع:" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                     Height="45" FontSize="18" Padding="12,0" BorderBrush="#CBD5E1" BorderThickness="1"
                     Background="White" InputScope="Number"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,7">
            <TextBlock Text="طريقة الدفع:" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ComboBox SelectedItem="{Binding PaymentType}" Height="45" FontSize="16" Padding="12,0">
                <ComboBoxItem Content="نقدي"/>
                <ComboBoxItem Content="تحويل"/>
            </ComboBox>
        </StackPanel>

        <Button Grid.Row="5" 
                Content="حفظ الدفعة" 
                Command="{Binding SavePaymentCommand}" 
                IsEnabled="{Binding IsSaveEnabled}" FontSize="18" FontWeight="Bold"
                Background="#10B981" Foreground="White" 
                BorderThickness="0"
                Cursor="Hand" Margin="0,33,0,48">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="16">
                                    <TextBlock Foreground="{TemplateBinding Foreground}"
                                               Text="{TemplateBinding Content}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#94A3B8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
