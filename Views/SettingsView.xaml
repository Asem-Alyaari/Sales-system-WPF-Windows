<UserControl x:Class="App2.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#CBD5E1" BlurRadius="20" ShadowDepth="2" Opacity="0.35" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="Control">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <TextBlock Text="⚙️ الإعدادات" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="إدارة بيانات حسابك الشخصي" FontSize="14" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- User Info + Change Username Card -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <!-- User Avatar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Background="#EFF6FF" CornerRadius="50" Width="60" Height="60" Margin="0,0,16,0">
                            <TextBlock Text="👤" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentFullName}" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock FontSize="13" Foreground="#64748B" Margin="0,4,0,0">
                                <Run Text="@"/><Run Text="{Binding CurrentUsername, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Fill="#F1F5F9" Height="1" Margin="0,0,0,24"/>

                    <!-- Change Username -->
                    <TextBlock Text="🔤 تغيير اسم المستخدم" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="اسم المستخدم الجديد" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource InputBoxStyle}"
                                     Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="💾 حفظ الاسم"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ChangeUsernameCommand}"
                                VerticalAlignment="Bottom"/>
                    </Grid>

                    <!-- Status for username -->
                    <Border x:Name="UsernameStatusBorder" CornerRadius="8" Padding="14,10" Margin="0,14,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="UsernameStatusText" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Change Password Card -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🔑 تغيير كلمة المرور" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                    <TextBlock Text="كلمة المرور الحالية" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="CurrentPwdBox" Style="{StaticResource InputBoxStyle}"
                                 Margin="0,0,0,16"
                                 PasswordChanged="CurrentPwdBox_PasswordChanged"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="كلمة المرور الجديدة" Style="{StaticResource LabelStyle}"/>
                            <PasswordBox x:Name="NewPwdBox" Style="{StaticResource InputBoxStyle}"
                                         PasswordChanged="NewPwdBox_PasswordChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource LabelStyle}"/>
                            <PasswordBox x:Name="ConfirmPwdBox" Style="{StaticResource InputBoxStyle}"
                                         PasswordChanged="ConfirmPwdBox_PasswordChanged"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="🔒 تغيير كلمة المرور"
                            Style="{StaticResource PrimaryBtn}"
                            Width="220" HorizontalAlignment="Right"
                            Command="{Binding ChangePasswordCommand}"
                            Click="ChangePassword_Click"/>

                    <!-- Status for password -->
                    <Border x:Name="PwdStatusBorder" CornerRadius="8" Padding="14,10" Margin="0,14,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="PwdStatusText" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- License Management Card -->
            <Border x:Name="LicenseCard" Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🔐 إدارة التراخيص" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="مفتاح الترخيص الجديد" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="LicenseKeyTextBox" Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True" FontFamily="Consolas" TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="تاريخ انتهاء الترخيص" Style="{StaticResource LabelStyle}"/>
                            <DatePicker x:Name="ExpiryDatePicker" Height="44" VerticalAlignment="Bottom"
                                        SelectedDate="{Binding Path=Today, Mode=OneTime}"/>
                        </StackPanel>
                        <Button Grid.Column="4" Content="🔄 إنشاء مفتاح"
                                Style="{StaticResource PrimaryBtn}"
                                Click="GenerateLicenseKey_Click"
                                VerticalAlignment="Bottom"/>
                    </Grid>

                    <TextBlock Text="استخدم هذا المفتاح لتفعيل النظام للعملاء الجدد" 
                               FontSize="12" Foreground="#64748B" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
