<Window x:Class="App2.Views.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيانات العميل" Height="380" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="إدارة بيانات العميل" FontSize="20" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            <Label Content="اسم العميل" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Height="35" Margin="0,0,0,15" Padding="5,8"/>

            <Label Content="رقم الجوال" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>
            <TextBox x:Name="PhoneTextBox" Height="35" Margin="0,0,0,15" Padding="5,8"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="إلغاء" Click="CancelButton_Click" Style="{StaticResource FlatButton}" Background="#94A3B8" Width="120" Height="40" Margin="0,0,10,0"/>
            <Button Content="حفظ البيانات" Click="SaveButton_Click" Style="{StaticResource FlatButton}" Background="#0F172A" Width="180" Height="40"/>
        </StackPanel>
    </Grid>
</Window>