<UserControl x:Class="App2.Views.SalesInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:App2.Models"
             Background="#E2E8F0" 
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <x:Array x:Key="UnitStrings" Type="sys:String">
            <sys:String>كرتون</sys:String>
            <sys:String>كبة</sys:String>
        </x:Array>
        
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="RoundedActionBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SolidCheckoutBtn">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#EA580C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton" x:Key="PosTabStyle">
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="InvoiceTabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#94A3B8"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <ListBox Grid.Row="0" Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Bottom" 
                 ItemsSource="{Binding Invoices}" SelectedItem="{Binding ActiveInvoice}"
                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="#CBD5E1" CornerRadius="8,8,0,0" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal" Margin="15,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <ContentPresenter Content="{Binding TabTitle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="✕" 
                                                Command="{Binding DataContext.CloseInvoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" 
                                                Foreground="#64748B" FontWeight="Bold" Cursor="Hand" 
                                                Padding="4,0" ToolTip="إغلاق הפاتورة"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FFFFFF"/>
                                        <Setter Property="TextElement.Foreground" Value="#0F172A"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="False"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                                        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
                                    </MultiTrigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="TextElement.Foreground" Value="#475569"/>
                                        <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border Grid.Row="1" Grid.Column="0" Background="#FFFFFF" Margin="0,0,15,0" CornerRadius="8,0,8,8" DataContext="{Binding ActiveInvoice}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,2" Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="رقم الفاتورة:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="---" FontSize="20" FontWeight="Black" Foreground="#0F172A" Margin="0,0,30,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="➕ فاتورة جديدة" Style="{StaticResource RoundedActionBtn}" Background="#3B82F6" Margin="0,0,10,0"
                                    Command="{Binding DataContext.NewInvoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="تجميد الفاتورة الحالية ⏸" Style="{StaticResource RoundedActionBtn}" Background="#F59E0B"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="بحث برقم اللون واختيار الدفعة:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox IsEditable="True" IsTextSearchEnabled="False"
                                      Text="{Binding SearchItemNumber, UpdateSourceTrigger=PropertyChanged}"
                                      IsDropDownOpen="{Binding IsDropdownOpen}"
                                      ItemsSource="{Binding AvailableBatches}" 
                                      SelectedItem="{Binding SelectedBatch}" 
                                      Background="#F8FAFC" BorderBrush="#E2E8F0" Height="45" FontSize="16" VerticalContentAlignment="Center" Padding="10,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2" Background="White" BorderThickness="1" BorderBrush="#E2E8F0" HeadersVisibility="Column" 
                          RowHeight="50" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          Margin="20,0,20,20" ItemsSource="{Binding Items}" AutoGenerateColumns="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الباركود/رقم الصنف" Binding="{Binding ThreadNumber}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="البيان (مثل: خيوط زري، قطن)" Binding="{Binding ItemName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <DataGridComboBoxColumn Header="الوحدة" SelectedItemBinding="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding Source={StaticResource UnitStrings}}" Width="100"/>
                        <DataGridTextColumn Header="الوزن (كجم)" Binding="{Binding Weight, StringFormat={}{0:F2}}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="السعر" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalPrice}" Width="140" IsReadOnly="True"/>
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✖" Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontWeight="Black" Cursor="Hand" FontSize="16"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#0F172A" CornerRadius="8" Padding="25" DataContext="{Binding ActiveInvoice}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="بيانات العميل (بحث بالاسم/الجوال)" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Background="#FFFFFF" Foreground="#0F172A" BorderBrush="#E2E8F0" Height="48" 
                                  IsEditable="True" IsTextSearchEnabled="True" 
                                  ItemsSource="{Binding DataContext.Customers, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedCustomer}"
                                  Text="ابحث عن عميل..." 
                                  FontSize="16" Padding="10,0">
                        </ComboBox>
                        <Button Grid.Column="1" Content="➕" Style="{StaticResource RoundedActionBtn}" Background="#3B82F6" Width="48" Margin="8,0,0,0" Padding="0" ToolTip="إضافة عميل جديد"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,30">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="المجموع" Foreground="#94A3B8" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="0.00" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الضريبة (15%)" Foreground="#94A3B8" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="0.00" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Grid>

                    <Border BorderBrush="#334155" BorderThickness="0,2,0,0" Padding="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="المطلوب" Foreground="#38BDF8" FontSize="22" FontWeight="Black" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="0.00" Foreground="#38BDF8" FontSize="36" FontWeight="Black"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <TextBlock Text="المدفوع نقداً" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox Background="#1E293B" Foreground="#10B981" BorderBrush="#334155" Text="0.00" FontSize="24" FontWeight="Bold" TextAlignment="Center" Height="55" Margin="0,0,0,20"/>

                    <TextBlock Text="المدفوع شبكة/تحويل" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox Background="#1E293B" Foreground="#818CF8" BorderBrush="#334155" Text="0.00" FontSize="24" FontWeight="Bold" TextAlignment="Center" Height="55" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="المتبقي (الآجل)" Foreground="#EF4444" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="0.00" Foreground="#EF4444" FontSize="26" FontWeight="Black"/>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="3" Style="{StaticResource SolidCheckoutBtn}" Content="طباعة واعتماد الفاتورة (F12)" Height="65" Margin="0,30,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>